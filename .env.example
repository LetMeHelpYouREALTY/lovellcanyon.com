# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Site Configuration — use www (must match GSC property + sitemap host)
NEXT_PUBLIC_SITE_URL=https://www.lovellcanyon.com

# Cloudflare R2 listing photos (bucket: listing-photos)
# Upload hero to lovell-canyon/hero.jpg and gallery to lovell-canyon/gallery/01.jpg, etc.
NEXT_PUBLIC_R2_MEDIA_BASE_URL=https://pub-55f2185197354e748b122f17b695df69.r2.dev

# Cloudflare Image Transformations (edge resize/format — originals stay on R2 only)
# Zone ID for lovellcanyon.com: 2d34470f3aa135ceb5d708a5f033085a
# Enable in dashboard or: scripts/enable-cloudflare-image-transformations.ps1
CLOUDFLARE_ZONE_ID=2d34470f3aa135ceb5d708a5f033085a
# CLOUDFLARE_API_TOKEN=          # Zone Settings Edit — do not commit
NEXT_PUBLIC_CLOUDFLARE_IMAGE_TRANSFORMATIONS=false
NEXT_PUBLIC_IMAGE_TRANSFORM_HOST=lovellcanyon.com

# Google Search Console — HTML tag verification (meta name="google-site-verification")
# 1. GSC → Add property → https://www.lovellcanyon.com (URL prefix or domain)
# 2. Settings → Ownership verification → HTML tag → copy content= value only
# 3. Set in Vercel → Project → Environment Variables → GOOGLE_SITE_VERIFICATION
# 4. Redeploy, then click Verify in GSC
# 5. Submit sitemap: https://www.lovellcanyon.com/sitemap.xml
GOOGLE_SITE_VERIFICATION=

# CallAction tracking number for lovellcanyon.com (WidgetTracker WT-XQHVYQWW)
# Override if your CallAction dashboard uses a different number
NEXT_PUBLIC_CALLACTION_PHONE=702-500-1942
