# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://lovellcanyon.com

# Cloudflare R2 listing photos (bucket: listing-photos)
# Upload hero to lovell-canyon/hero.jpg and gallery to lovell-canyon/gallery/01.jpg, etc.
NEXT_PUBLIC_R2_MEDIA_BASE_URL=https://pub-55f2185197354e748b122f17b695df69.r2.dev

# Google Search Console — HTML tag verification (meta name="google-site-verification")
# Copy the content value from GSC → Settings → Ownership verification → HTML tag
GOOGLE_SITE_VERIFICATION=
